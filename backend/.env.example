# TradeX backend — copy to `.env` and adjust. All keys use the TRADEX_ prefix.

# development | production
TRADEX_ENVIRONMENT=development

# Required in production. In development, a fixed dev default is used if unset (not for real deployments).
TRADEX_JWT_SECRET=

# JWT lifetime in days
TRADEX_JWT_ACCESS_DAYS=14

# Comma-separated CORS origins (your deployed frontend URL(s) in production), e.g. https://tradex.vercel.app
TRADEX_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# If the frontend is on Vercel (production + *.vercel.app previews), set true OR list each origin above.
TRADEX_CORS_ALLOW_VERCEL_HOSTS=false

# Staging only: allow any browser Origin (sets Access-Control-Allow-Origin: *; credentials off)
TRADEX_CORS_ALLOW_ALL=false

# Optional CORS regex (defaults in development to localhost with any port)
# TRADEX_CORS_ORIGIN_REGEX=

# SQLite default: backend/data/tradex.db — set for Postgres etc. on production hosts.
# On Render with a Postgres add-on, the platform sets DATABASE_URL; you can also set TRADEX_DATABASE_URL to the same value.
# TRADEX_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# Local dev port when using python run.py (Render sets PORT automatically; overrides this)
# TRADEX_PORT=10000

# Render / Docker production start (from backend/ directory):
#   uvicorn main:app --host 0.0.0.0 --port $PORT --proxy-headers --forwarded-allow-ips '*'
# (Render injects PORT; see render.yaml startCommand.)

# Logging: DEBUG, INFO, WARNING, ERROR
TRADEX_LOG_LEVEL=INFO

# Local LLM (optional; paper app only)
TRADEX_OLLAMA_GENERATE_URL=http://127.0.0.1:11434/api/generate
TRADEX_OLLAMA_MODEL=llama3.2

# Per-user Binance API key encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TRADEX_EXCHANGE_FERNET_KEY=

# Hard cap on fraction of exchange balance per bot order (additional safety vs user max_trade_fraction)
TRADEX_EXCHANGE_MAX_TRADE_FRACTION=0.02

# Binance Spot API bases (override only if Binance changes URLs)
# TRADEX_BINANCE_SPOT_TESTNET_BASE=https://testnet.binance.vision
# TRADEX_BINANCE_SPOT_LIVE_BASE=https://api.binance.com
