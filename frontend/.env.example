# Public API base (no secrets — inlined into the browser bundle). No trailing slash.
# Local dev (match your backend port, e.g. 8010 or 10000):
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
# Production (Vercel, etc.) — your deployed FastAPI origin, e.g.:
# NEXT_PUBLIC_API_URL=https://tradex-api.onrender.com
#
# Backend must allow this origin: set TRADEX_CORS_ORIGINS (and optionally TRADEX_CORS_ALLOW_VERCEL_HOSTS=true
# for all *.vercel.app previews) on the API server.

# Canonical URL for sitemap, robots.txt, and Open Graph (set on Vercel Production + Preview if needed)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: informational only if you read it in UI (NODE_ENV is authoritative for Next)
# NEXT_PUBLIC_APP_ENV=development